# Multi-Agent Research Assistant — Environment Variables
# Copy this file to .env and fill in your Groq API key.

GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# API / CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# WhatsApp (optional)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_VERIFY_TOKEN=
# WEBHOOK_SECRET=
